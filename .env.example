PORT=3333
# Comma-separated allowed browser origins for deployed frontends.
# In development, localhost/127.0.0.1 are accepted on any port.
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=604800

# DATABASE_URL has priority over the DB_* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seo_genius

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=seo_genius
DB_SSL=false
DB_SYNCHRONIZE=false

# AI provider
# Gemini is the application default. Use "demo" only for local tests without key.
AI_PROVIDER=gemini
AI_APP_CONTEXT=
AI_DEMO_MODEL=demo-local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
