NODE_ENV=development
PORT=3001

# Local API base: http://localhost:3001/api
# Comma-separated allowed browser origins for deployed frontends.
# In development, localhost/127.0.0.1 are accepted on any port.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

JWT_SECRET=dev-only-change-me-at-least-32-characters
JWT_EXPIRES_IN_SECONDS=604800
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

# DATABASE_URL has priority over the DB_* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seo_genius

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=seo_genius
DB_SSL=false
DB_SYNCHRONIZE=false

# AI provider
# Gemini is the application default. Use "demo" only for local tests without key.
AI_PROVIDER=gemini
AI_APP_CONTEXT=
AI_DEMO_MODEL=demo-local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
# --- Integration Notion ---
# Token d'integration interne Notion (fallback global du socle).
NOTION_TOKEN=secret_...
# Identifiants des bases Notion (template Content marketing & curation).
NOTION_CONTENT_DATABASE_ID=
NOTION_CURATION_DATABASE_ID=
# Synchronisation periodique : desactivee par defaut (test/CI).
NOTION_SYNC_ENABLED=false
NOTION_SYNC_CRON=*/5 * * * *

# Generation automatique d'idees SEO : configuree par agence depuis l'UI.
# Les jobs sont programmes dynamiquement a l'heure locale choisie.
