NODE_ENV=development
PORT=3001

# Local API base: http://localhost:3001/api
# Comma-separated allowed browser origins for deployed frontends.
# In development, localhost/127.0.0.1 are accepted on any port.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

JWT_SECRET=dev-only-change-me-at-least-32-characters
JWT_EXPIRES_IN_SECONDS=604800
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

# DATABASE_URL has priority over the DB_* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seo_genius

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=seo_genius
DB_SSL=false
DB_SYNCHRONIZE=false

# AI provider
# Gemini is the application default. Use "demo" only for local tests without key.
AI_PROVIDER=gemini
AI_APP_CONTEXT=
AI_DEMO_MODEL=demo-local
# Secret serveur pour chiffrer les cles configurees depuis l'application.
# Obligatoire en production; ne pas modifier cette valeur apres avoir enregistre une cle.
AI_SETTINGS_ENCRYPTION_KEY=change-me-to-a-long-random-secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
# --- Integration Notion ---
# Token d'integration interne Notion (fallback global du socle).
NOTION_TOKEN=secret_...
# Identifiants des bases Notion (template Content marketing & curation).
NOTION_CONTENT_DATABASE_ID=
NOTION_CURATION_DATABASE_ID=
# Synchronisation periodique : desactivee par defaut (test/CI).
NOTION_SYNC_ENABLED=false
NOTION_SYNC_CRON=*/5 * * * *
# OAuth Notion (integration publique, connexion par agence).
# Redirect URI a declarer a l'identique dans les parametres de l'integration Notion.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3333/api/notion/oauth/callback

# Curation : ingestion RSS et retention
# Ingestion RSS planifiee (cron horaire). Desactivee par defaut : ingestion
# manuelle via POST /agencies/:agencyId/curation/feeds[/:id]/ingest.
RSS_CRON_ENABLED=false
# Retention des ressources en base (jours) avant purge des elements deja
# archives dans Notion (syncStatus=SYNCED). Les PENDING/ERROR sont conserves.
RETENTION_DAYS=30
